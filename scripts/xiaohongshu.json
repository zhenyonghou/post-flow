{
  "publishUrl": "https://creator.xiaohongshu.com/publish/publish",
  "loggedInSelector": "[data-e2e='user-avatar'], .avatar, [class*='avatar']",
  "scripts": [
    {
      "id": "video",
      "title": "发视频",
      "steps": []
    },
    {
      "id": "image_text",
      "title": "发图文",
      "steps": [
        {
          "kind": "click",
          "selector": ".header-tabs .creator-tab:has(.title:has-text(\"上传图文\")):not([style*=\"left: -9999\"]) .title",
          "desc": "创作服务平台发布页，点击“上传图文”标签"
        },
        {
          "kind": "click",
          "selector": ".upload-content button.upload-button:has-text(\"上传图片\")",
          "desc": "创作服务平台发布笔记上传图文页，点击“上传图片”按钮"
        },
        {
          "kind": "file",
          "selector": ".upload-c input[type=\"file\"].upload-input",
          "value": "{{image_paths}}",
          "desc": "创作服务平台发布页的图文上传区域，选择图片文件进行上传"
        },
        {
          "kind": "type",
          "selector": "input[placeholder=\"填写标题会有更多赞哦\"]",
          "value": "{{title}}",
          "desc": "在创作服务平台的笔记发布页，在标题输入框中输入内容"
        },
        {
          "kind": "type",
          "selector": ".tiptap-container [contenteditable='true'] p[data-placeholder=\"输入正文描述，真诚有价值的分享予人温暖\"]",
          "value": "{{content}}",
          "desc": "创作服务平台的笔记发布页，在正文编辑框输入内容"
        },
        {
          "kind": "wait",
          "selector": "",
          "value": "1000",
          "desc": "点发布前等待 1 秒"
        },
        {
          "kind": "click",
          "selector": ".publish-page-publish-btn button:has-text(\"发布\")",
          "desc": "创作服务平台的笔记发布页，点击“发布”按钮"
        }
      ]
    },
    {
      "id": "long_text",
      "title": "发长文",
      "steps": [
        {
          "kind": "click",
          "selector": ".header-tabs .creator-tab:has-text(\"写长文\")",
          "desc": "发布页创作服务平台，点击“写长文”标签"
        },
        {
          "kind": "click",
          "selector": "role=button[name=\"新的创作\"]",
          "desc": "创作服务平台长文发布页，点击“新的创作”按钮"
        },
        {
          "kind": "type",
          "selector": ".rich-editor-title textarea[placeholder=\"输入标题\"]",
          "value": "{{title}}",
          "desc": "笔记编辑页，在标题输入框中输入内容"
        },
        {
          "kind": "type",
          "selector": ".rich-editor-content p[data-placeholder=\"粘贴到这里或输入文字\"]",
          "value": "{{content}}",
          "desc": "创作服务平台的新建笔记编辑页，在正文编辑区输入内容"
        },
        {
          "kind": "click",
          "selector": "button.next-btn:has-text(\"一键排版\")",
          "desc": "创作服务平台的笔记编辑页，点击“一键排版”按钮"
        },
        {
          "kind": "wait",
          "selector": "",
          "value": "6000",
          "desc": "一键排版后等待 6 秒"
        },
        {
          "kind": "click",
          "selector": ".template-card:has(.template-title:has-text(\"轻感明快\"))",
          "desc": "发布页模板选择弹窗中，点击“轻感明快”模板的封面图"
        },
        {
          "kind": "click",
          "selector": ".template-card:has(.template-title:has-text(\"轻感明快\")) span.color-item[style*=\"FFFFAA\"]",
          "desc": "轻感明快模板下，选择颜色 #FFFFAA"
        },
        {
          "kind": "click",
          "selector": ".template-card:has(.template-title:has-text(\"灵感备忘\"))",
          "desc": "发布页模板选择弹窗中，点击“灵感备忘”模板的封面图"
        },
        {
          "kind": "click",
          "selector": "button.submit:has-text(\"下一步\")",
          "desc": "在模板编辑预览页面点击“下一步”按钮"
        },
        {
          "kind": "wait",
          "selector": "",
          "value": "1000",
          "desc": "点发布前等待 1 秒"
        },
        {
          "kind": "click",
          "selector": ".publish-page-publish-btn button.bg-red",
          "desc": "创作服务平台笔记发布页中，点击“发布”按钮提交笔记"
        }
      ]
    }
  ]
}
